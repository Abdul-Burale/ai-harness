generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PromptTemplate {
  id           String   @id @default(cuid())
  name         String
  systemPrompt String?
  userPrompt   String
  modelId      String
  settings     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Run {
  id           String   @id @default(cuid())
  modelId      String
  systemPrompt String?
  userPrompt   String
  settings     Json
  output       String   @default("")
  usage        Json?
  latencyMs    Int
  rawResponse  Json?
  error        String?
  createdAt    DateTime @default(now())
}
