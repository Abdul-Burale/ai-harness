{
  "name": "ai-harness",
  "version": "0.1.0",
  "description": "A local-first AWS Bedrock prompt evaluation CLI with a static product demo.",
  "license": "MIT",
  "bin": {
    "ai-harness": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "tsup",
    "build:web": "next build",
    "cli": "node --import tsx src/cli/index.ts",
    "cli:doctor": "node --import tsx src/cli/index.ts doctor",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.600.0",
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-sts": "^3.600.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
